{
  "name": "contractos",
  "version": "0.1.0",
  "description": "SBS 방송 계약서 자동 작성·관리 플랫폼",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "open": "open index.html",
    "vercel:deploy": "npx vercel --prod --yes",
    "vercel:link": "npx vercel link",
    "supabase": "npx supabase",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:db:push": "npx supabase db push",
    "supabase:types": "npx supabase gen types typescript --linked --schema public > src/lib/supabase/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "docx": "^9.6.1",
    "docx-preview": "^0.3.7",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
