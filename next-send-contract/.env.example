# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxx

# Verified domain sender, e.g. ContractOS <contracts@yourdomain.com>
RESEND_FROM_EMAIL=ContractOS <contracts@yourdomain.com>

# CORS: Vite 앱 Origin (쉼표 구분). 프로덕션·로컬 모두 넣을 것
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://sbsmccontract.vercel.app

# 선택: 설정 시 요청 헤더 X-ContractOS-Notify-Secret 와 값이 같아야 함 (VITE_NOTIFY_SECRET)
# NOTIFY_SECRET=your_random_secret

# Optional: default base URL for contract links when request omits contractUrl
# NEXT_PUBLIC_APP_URL=https://app.example.com
