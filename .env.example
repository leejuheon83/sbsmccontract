# ─── Supabase 연동 (ContractOS 프로젝트) ───
# 대시보드: https://supabase.com/dashboard/project/aqyohyayucprcwqftkln
# API 키: 위 프로젝트 → Project Settings → API → Project URL / anon public key
#
# 1) 이 파일을 복사해 `.env.local` 로 저장
# 2) 아래 VITE_SUPABASE_ANON_KEY 에 anon public key 만 붙여넣기 (Git에 커밋하지 말 것)
# 3) SQL Editor 에서 마이그레이션 순서대로 실행
#    - supabase/migrations/20250407120000_app_users.sql
#    - supabase/migrations/20250408120000_managed_template_catalog.sql
# 4) `npm run dev` 재시작 → 로그인 화면·상단바에서 Supabase 연결 여부 확인
# 로컬 DB: `npm run supabase:start` (Docker). 원격 반영: `npx supabase link` 후 `npm run supabase:db:push`
#
VITE_SUPABASE_URL=https://aqyohyayucprcwqftkln.supabase.co
VITE_SUPABASE_ANON_KEY=

# 확정(검토 요청) 시 경영지원팀 알림 메일 — next-send-contract 배포 URL + Resend
# VITE_NOTIFY_REVIEW_API_URL=https://your-next-app.vercel.app/api/notify-review-request
# VITE_REVIEW_NOTIFY_TO=legal@example.com,support@example.com
# VITE_PUBLIC_APP_URL=https://your-vite-app.vercel.app
# VITE_NOTIFY_SECRET=same_as_server_NOTIFY_SECRET
